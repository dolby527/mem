# Copy to env/.env.development (gitignored)
# Local dev: direct API. Render: NEXT_PUBLIC_API_URL=/mem-api + API_INTERNAL_URL (see docs/deploy/RENDER.md)
NEXT_PUBLIC_API_URL=http://localhost:3001
# API_INTERNAL_URL=https://mem-api-xxxx.onrender.com
JWT_SECRET=mem_dev_jwt_secret_change_in_production_32chars_min
# PLATFORM_ADMIN 조회 병원 (x-hospital-slug)
NEXT_PUBLIC_DEV_HOSPITAL_SLUG=asan
