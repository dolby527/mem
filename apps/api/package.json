{
  "name": "@mem/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "eslint \"{src,prisma}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "postinstall": "prisma generate",
    "db:migrate": "node --env-file=env/.env.development ./node_modules/prisma/build/index.js migrate dev",
    "db:push": "node --env-file=env/.env.development ./node_modules/prisma/build/index.js db push",
    "db:seed": "node --env-file=env/.env.development ./node_modules/prisma/build/index.js db seed",
    "db:studio": "node --env-file=env/.env.development ./node_modules/prisma/build/index.js studio",
    "sim:protocol": "node --env-file=env/.env.development node_modules/tsx/dist/cli.mjs scripts/simulate-protocol-events.ts"
  },
  "dependencies": {
    "@nestjs/common": "10.4.17",
    "@nestjs/config": "3.3.0",
    "@nestjs/core": "10.4.17",
    "@nestjs/mapped-types": "2.0.6",
    "@nestjs/platform-express": "10.4.17",
    "@prisma/client": "6.8.2",
    "bcrypt": "^6.0.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.2",
    "cookie-parser": "^1.4.7",
    "jsonwebtoken": "^9.0.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.9",
    "@nestjs/schematics": "10.2.3",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "5.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node": "22.15.21",
    "eslint": "9.28.0",
    "prisma": "6.8.2",
    "tsx": "4.19.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.33.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
