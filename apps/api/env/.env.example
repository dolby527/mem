# Copy to env/.env.development (gitignored)
# Production (Render): set in Dashboard only — see docs/deploy/RENDER.md
DATABASE_URL="postgresql://mem:mem@localhost:5432/mem?schema=public"
PORT=3001
CORS_ORIGIN="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"
JWT_SECRET="mem_dev_jwt_secret_change_in_production_32chars_min"
# Cookie (production / cross-host deploy)
# COOKIE_DOMAIN=
# COOKIE_SAMESITE=lax
# COOKIE_SECURE=

# Monitoring (see docs/MONITORING.md)
HEALTH_CHECK_INTERVAL_MS=30000
HEALTH_CHECK_BATCH_SIZE=50
HEALTH_CHECK_TIMEOUT_MS=5000
PING_FAILURE_THRESHOLD=3
INTERFACE_VENDOR_STALE_MS=300000
AGENT_HEARTBEAT_STALE_MS=60000
IOT_READING_STALE_MS=120000
SSE_KEEPALIVE_MS=15000
# Simulate PING for equipment without devProbeHost (dev/demo)
HEALTH_CHECK_SIMULATE=true

# Equipment images (local disk; monorepo uploads/equipment by default)
# EQUIPMENT_IMAGE_UPLOAD_DIR=../../uploads/equipment
